{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "version": "1.6.3",
  "author": "segelferd",
  "homepage_url": "https://github.com/segelferd/kick-alert",
  "default_locale": "en",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "html/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "js": [
        "src/content.js"
      ],
      "matches": [
        "https://kick.com/*"
      ]
    }
  ],
  "permissions": [
    "storage",
    "offscreen",
    "notifications",
    "declarativeNetRequestWithHostAccess",
    "cookies",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://kick.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "enabled": true,
        "id": "ruleset_1",
        "path": "rules.json"
      }
    ]
  }
}