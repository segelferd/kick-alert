{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "version": "1.5.1",
  "author": "segelferd",
  "homepage_url": "https://github.com/segelferd/kick-alert",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "kickalert@segelferd",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "html/popup.html"
  },
  "background": {
    "scripts": ["src/storage.js", "src/kickapi.js", "src/utils.js", "src/background.js"]
  },
  "content_scripts": [
    {
      "js": ["src/content.js"],
      "matches": ["https://kick.com/*"]
    }
  ],
  "permissions": [
    "storage",
    "notifications",
    "declarativeNetRequest",
    "cookies",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://kick.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "enabled": true,
        "id": "ruleset_1",
        "path": "rules.json"
      }
    ]
  }
}
